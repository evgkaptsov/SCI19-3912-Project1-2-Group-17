digraph DFA {
    rankdir=LR;
    node [shape = doublecircle]; stateB stateC ;
    node [shape = circle];
    start [shape=point];
    start -> stateA;
    stateA -> stateA [label="a"];
    stateA -> stateB [label="b"];
    stateA -> stateC [label="c"];
    stateC -> stateC [label="a"];
    stateC -> stateB [label="b"];
    stateC -> stateC [label="c"];
    stateB -> stateC [label="a"];
    stateB -> stateB [label="b"];
    stateB -> stateA [label="c"];
}
