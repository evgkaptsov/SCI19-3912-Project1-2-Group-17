digraph DFA {
    rankdir=LR;
    node [shape = doublecircle]; stateA stateC ;
    node [shape = circle];
    start [shape=point];
    start -> stateB;
    stateB -> stateB [label="a"];
    stateB -> stateA [label="b"];
    stateB -> stateC [label="c"];
    stateC -> stateC [label="a"];
    stateC -> stateA [label="b"];
    stateC -> stateC [label="c"];
    stateA -> stateC [label="a"];
    stateA -> stateA [label="b"];
    stateA -> stateB [label="c"];
}
