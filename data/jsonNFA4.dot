digraph DFA {
    rankdir=LR;
    node [shape = doublecircle]; stateE stateB stateA ;
    node [shape = circle];
    start [shape=point];
    start -> stateB;
    stateB -> stateE [label="0"];
    stateB -> stateA [label="1"];
    stateA -> stateC [label="0"];
    stateA -> stateA [label="1"];
    stateC -> stateC [label="0"];
    stateC -> stateA [label="1"];
    stateE -> stateE [label="0"];
    stateE -> stateD [label="1"];
    stateD -> stateE [label="0"];
    stateD -> stateD [label="1"];
}
