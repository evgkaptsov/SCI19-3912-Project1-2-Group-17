digraph DFA {
    rankdir=LR;
    node [shape = doublecircle]; stateB stateC stateE ;
    node [shape = circle];
    start [shape=point];
    start -> stateB;
    stateB -> stateC [label="0"];
    stateB -> stateE [label="1"];
    stateE -> stateA [label="0"];
    stateE -> stateE [label="1"];
    stateA -> stateA [label="0"];
    stateA -> stateE [label="1"];
    stateC -> stateC [label="0"];
    stateC -> stateD [label="1"];
    stateD -> stateC [label="0"];
    stateD -> stateD [label="1"];
}
